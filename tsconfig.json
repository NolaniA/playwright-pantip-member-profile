{
  "compilerOptions": {

    "target": "ESNext",

    "module": "Node16",

    "moduleResolution": "Node16",
    "ignoreDeprecations": "6.0",

    "types": [
      "node",
      "@playwright/test"
    ],

    "strict": true,

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "skipLibCheck": true

  },

  "include": [
    "**/*.ts"
  ]

}